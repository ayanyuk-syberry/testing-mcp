{
  "realm": "mcp",
  "enabled": true,
  "displayName": "MCP Experiment",
  "sslRequired": "none",
  "users": [
    {
      "username": "alex",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Alex",
      "lastName": "Tester",
      "email": "alex@example.com",
      "realmRoles": [
        "offline_access"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "alex123",
          "temporary": false
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "test-cli",
      "name": "Headless test client (direct access grant, for curl verification only)",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "protocol": "openid-connect"
    },
    {
      "clientId": "claude-code",
      "name": "Claude Code (manually pre-registered static client, alternative to CIMD)",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:8765/callback",
        "http://127.0.0.1:8765/callback"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "oauth2-proxy",
      "name": "oauth2-proxy (confidential reverse-proxy client, browser cookie flow for manual testing)",
      "enabled": true,
      "publicClient": false,
      "secret": "oauth2-proxy-secret",
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:8000/oauth2/callback"
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "profile",
      "description": "OIDC profile scope, also carries the hello-mcp audience + identity claims so dynamically registered clients (which lose realm defaults) still mint valid tokens",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "hello-mcp-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "http://localhost:8000/mcp",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        },
        {
          "name": "sub",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "email",
            "claim.name": "email",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "email",
      "description": "OIDC email scope (claims provided by hello-mcp-claims)",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "hello-mcp-claims",
      "description": "Audience + identity claims for the hello-mcp resource server",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "hello-mcp-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "http://localhost:8000/mcp",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        },
        {
          "name": "sub",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "email",
            "claim.name": "email",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "defaultDefaultClientScopes": [
    "hello-mcp-claims",
    "profile",
    "email"
  ],
  "clientProfiles": {
    "profiles": [
      {
        "name": "cimd-profile",
        "description": "Accept CIMD clients (sandbox: any domain, http allowed)",
        "executors": [
          {
            "executor": "client-id-metadata-document",
            "configuration": {
              "cimd-allow-http-scheme": true,
              "cimd-restrict-same-domain": false,
              "cimd-allow-permitted-domains": [
                "claude.ai",
                "*.claude.ai",
                "claude.com",
                "*.claude.com",
                "anthropic.com",
                "*.anthropic.com",
                "host.docker.internal",
                "localhost",
                "127.0.0.1"
              ],
              "only-allow-confidential-client": false
            }
          }
        ]
      }
    ]
  },
  "clientPolicies": {
    "policies": [
      {
        "name": "cimd-policy",
        "description": "Apply CIMD acceptance to URL client_ids",
        "enabled": true,
        "conditions": [
          {
            "condition": "client-id-uri",
            "configuration": {
              "client-id-uri-scheme": [
                "http",
                "https"
              ],
              "client-id-uri-allow-permitted-domains": [
                "claude.ai",
                "*.claude.ai",
                "claude.com",
                "*.claude.com",
                "anthropic.com",
                "*.anthropic.com",
                "host.docker.internal",
                "localhost",
                "127.0.0.1"
              ]
            }
          }
        ],
        "profiles": [
          "cimd-profile"
        ]
      }
    ]
  },
  "components": {
    "org.keycloak.services.clientregistration.policy.ClientRegistrationPolicy": [
      {
        "name": "Trusted Hosts",
        "providerId": "trusted-hosts",
        "subType": "anonymous",
        "subComponents": {},
        "config": {
          "trusted-hosts": [
            "localhost",
            "127.0.0.1"
          ],
          "host-sending-registration-request-must-match": [
            "false"
          ],
          "client-uris-must-match": [
            "true"
          ]
        }
      },
      {
        "name": "Max Clients Limit",
        "providerId": "max-clients",
        "subType": "anonymous",
        "subComponents": {},
        "config": {
          "max-clients": [
            "200"
          ]
        }
      }
    ]
  }
}
